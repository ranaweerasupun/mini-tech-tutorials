# config.env.example
# -------------------
# Template for /etc/env-service/config.env
#
# SETUP INSTRUCTIONS:
#   1. Copy this file to the protected location:
#        sudo mkdir -p /etc/env-service
#        sudo cp config.env.example /etc/env-service/config.env
#
#   2. Edit the file and replace placeholder values with real ones:
#        sudo nano /etc/env-service/config.env
#
#   3. Restrict permissions so only root can read the secrets:
#        sudo chmod 600 /etc/env-service/config.env
#        sudo chown root:root /etc/env-service/config.env
#
#   4. Start the service:
#        sudo systemctl restart env-example.service
#
# FORMAT RULES:
#   - One variable per line: KEY=VALUE
#   - No spaces around the equals sign
#   - No quotes around values (unlike shell syntax)
#   - Lines starting with # are comments and are ignored
#   - No 'export' keyword — this is not a shell script

# -----------------------------------------------------------------------
# Required — the service will fail to start if these are not set
# -----------------------------------------------------------------------

# Your API authentication key
API_KEY=replace-with-your-real-api-key

# The hostname or IP address of your MQTT broker
BROKER_HOST=mqtt.example.com

# -----------------------------------------------------------------------
# Optional — these have sensible defaults in the application code
# -----------------------------------------------------------------------

# MQTT broker port (default: 1883, use 8883 for TLS)
BROKER_PORT=1883

# Database password (only required if your app uses a database)
# DB_PASSWORD=replace-with-your-db-password
